<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Purab AI - Indranil Officials</title>
  <link href="https://fonts.googleapis.com/css2?family=Spline+Sans:wght@400;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #D2691E;
      --primary-dark: #C1440E;
      --bg-dark: #2E2459;
      --bg-darker: #1F1740;
      --text-light: #F5F5F5;
      --text-dim: #B8B8D1;
      --border: #4A3F7A;
      --success: #4CAF50;
      --error: #FF6B6B;
    }

    body {
      font-family: 'Spline Sans', sans-serif;
      background: linear-gradient(135deg, var(--bg-darker) 0%, var(--bg-dark) 100%);
      color: var(--text-light);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    /* API Key Setup Screen */
    #setup-screen {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 20px;
      gap: 30px;
    }

    .logo-container {
      display: flex;
      align-items: center;
      gap: 20px;
      animation: fadeInUp 0.8s ease-out;
    }

    .logo-box {
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      border-radius: 16px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(210, 105, 30, 0.3);
    }

    .logo-segment {
      width: 100%;
      height: 100%;
    }

    .logo-segment:nth-child(1) {
      background: #D2691E;
      border-radius: 0 0 100% 0;
    }

    .logo-segment:nth-child(2) {
      background: #C1440E;
    }

    .logo-segment:nth-child(3) {
      background: #2E2459;
      border-radius: 0 100% 0 0;
    }

    .logo-segment:nth-child(4) {
      background: #3B5998;
    }

    .brand-text {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .brand-name {
      font-size: 32px;
      font-weight: 700;
      color: var(--primary);
      letter-spacing: -0.5px;
    }

    .brand-tagline {
      font-size: 13px;
      color: var(--text-dim);
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .setup-card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 40px 30px;
      width: 100%;
      max-width: 440px;
      animation: fadeInUp 0.8s ease-out 0.2s backwards;
    }

    .setup-title {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 10px;
      text-align: center;
    }

    .setup-subtitle {
      font-size: 14px;
      color: var(--text-dim);
      margin-bottom: 30px;
      text-align: center;
    }

    .input-group {
      margin-bottom: 20px;
    }

    .input-group label {
      display: block;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--text-dim);
    }

    .input-group input {
      width: 100%;
      padding: 14px 16px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--text-light);
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      transition: all 0.3s;
    }

    .input-group input:focus {
      outline: none;
      border-color: var(--primary);
      background: rgba(255, 255, 255, 0.12);
      box-shadow: 0 0 0 3px rgba(210, 105, 30, 0.15);
    }

    .btn-primary {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      border: none;
      border-radius: 12px;
      color: white;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(210, 105, 30, 0.3);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(210, 105, 30, 0.4);
    }

    .btn-primary:active {
      transform: translateY(0);
    }

    .error-msg {
      background: rgba(255, 107, 107, 0.15);
      border: 1px solid var(--error);
      border-radius: 10px;
      padding: 12px;
      margin-top: 15px;
      font-size: 14px;
      color: var(--error);
      display: none;
    }

    /* Chat Screen */
    #chat-screen {
      display: none;
      flex-direction: column;
      height: 100vh;
      max-height: 100vh;
    }

    .chat-header {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      padding: 15px 20px;
      display: flex;
      align-items: center;
      gap: 15px;
      flex-shrink: 0;
    }

    .header-avatar {
      width: 45px;
      height: 45px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 18px;
      box-shadow: 0 4px 12px rgba(210, 105, 30, 0.3);
    }

    .header-info {
      flex: 1;
    }

    .header-name {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 2px;
    }

    .header-status {
      font-size: 12px;
      color: var(--success);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--success);
      animation: pulse 2s infinite;
    }

    .header-actions {
      display: flex;
      gap: 10px;
    }

    .icon-btn {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 18px;
    }

    .icon-btn:hover {
      background: rgba(255, 255, 255, 0.15);
      border-color: var(--primary);
    }

    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .message {
      display: flex;
      gap: 12px;
      max-width: 85%;
      animation: slideIn 0.3s ease-out;
    }

    .message.user {
      align-self: flex-end;
      flex-direction: row-reverse;
    }

    .message-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 14px;
    }

    .message.bot .message-avatar {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    }

    .message.user .message-avatar {
      background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
    }

    .message-content {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 12px 16px;
      word-wrap: break-word;
      line-height: 1.5;
    }

    .message.user .message-content {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      border-color: var(--primary);
    }

    .message-image {
      max-width: 100%;
      border-radius: 12px;
      margin-top: 8px;
    }

    .typing-indicator {
      display: none;
      gap: 4px;
      padding: 12px 16px;
    }

    .typing-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--text-dim);
      animation: typing 1.4s infinite;
    }

    .typing-dot:nth-child(2) {
      animation-delay: 0.2s;
    }

    .typing-dot:nth-child(3) {
      animation-delay: 0.4s;
    }

    .chat-input-area {
      padding: 15px 20px;
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }

    .input-container {
      display: flex;
      gap: 10px;
      align-items: flex-end;
    }

    .input-actions {
      display: flex;
      gap: 8px;
    }

    .input-btn {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 20px;
      flex-shrink: 0;
    }

    .input-btn:hover {
      background: rgba(255, 255, 255, 0.15);
      border-color: var(--primary);
    }

    .input-btn.recording {
      background: var(--error);
      border-color: var(--error);
      animation: pulse 1s infinite;
    }

    #message-input {
      flex: 1;
      padding: 12px 16px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--text-light);
      font-family: 'Spline Sans', sans-serif;
      font-size: 15px;
      resize: none;
      max-height: 120px;
      transition: all 0.3s;
    }

    #message-input:focus {
      outline: none;
      border-color: var(--primary);
      background: rgba(255, 255, 255, 0.12);
    }

    .send-btn {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      border-color: var(--primary);
      color: white;
    }

    .send-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(210, 105, 30, 0.4);
    }

    /* Hidden inputs */
    #image-input {
      display: none;
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-10px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes pulse {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.5;
      }
    }

    @keyframes typing {
      0%, 60%, 100% {
        transform: translateY(0);
      }
      30% {
        transform: translateY(-10px);
      }
    }

    /* Mobile optimizations */
    @media (max-width: 768px) {
      .setup-card {
        padding: 30px 20px;
      }

      .brand-name {
        font-size: 28px;
      }

      .logo-box {
        width: 70px;
        height: 70px;
      }

      .message {
        max-width: 90%;
      }

      .chat-messages {
        padding: 15px;
      }
    }

    /* Scrollbar */
    .chat-messages::-webkit-scrollbar {
      width: 6px;
    }

    .chat-messages::-webkit-scrollbar-track {
      background: transparent;
    }

    .chat-messages::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px;
    }

    .chat-messages::-webkit-scrollbar-thumb:hover {
      background: var(--primary);
    }
  </style>
</head>
<body>
  <!-- API Key Setup Screen -->
  <div id="setup-screen">
    <div class="logo-container">
      <div class="logo-box">
        <div class="logo-segment"></div>
        <div class="logo-segment"></div>
        <div class="logo-segment"></div>
        <div class="logo-segment"></div>
      </div>
      <div class="brand-text">
        <div class="brand-name">PURAB AI</div>
        <div class="brand-tagline">Indranil Officials</div>
      </div>
    </div>

    <div class="setup-card">
      <h2 class="setup-title">Welcome to Purab AI</h2>
      <p class="setup-subtitle">Enter your Anthropic API key to get started</p>
      
      <div class="input-group">
        <label for="api-key-input">Anthropic API Key</label>
        <input type="password" id="api-key-input" placeholder="sk-ant-api03-...">
      </div>

      <button class="btn-primary" onclick="saveApiKey()">Start Chatting</button>
      
      <div class="error-msg" id="error-msg"></div>
    </div>
  </div>

  <!-- Chat Screen -->
  <div id="chat-screen">
    <div class="chat-header">
      <div class="header-avatar">PA</div>
      <div class="header-info">
        <div class="header-name">Purab AI</div>
        <div class="header-status">
          <span class="status-dot"></span>
          Online
        </div>
      </div>
      <div class="header-actions">
        <div class="icon-btn" onclick="clearMemory()" title="Clear Memory">🗑️</div>
        <div class="icon-btn" onclick="logout()" title="Logout">🚪</div>
      </div>
    </div>

    <div class="chat-messages" id="chat-messages"></div>

    <div class="chat-input-area">
      <div class="input-container">
        <div class="input-actions">
          <div class="input-btn" onclick="document.getElementById('image-input').click()" title="Send Image">📷</div>
          <div class="input-btn" id="voice-btn" onclick="toggleVoice()" title="Voice Input">🎤</div>
        </div>
        <textarea id="message-input" placeholder="Type your message..." rows="1" onkeypress="handleKeyPress(event)"></textarea>
        <div class="input-btn send-btn" onclick="sendMessage()">📤</div>
      </div>
    </div>

    <input type="file" id="image-input" accept="image/*" onchange="handleImageUpload(event)">
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script>
    let apiKey = '';
    let conversationHistory = [];
    let quizMode = false;
    let quizStep = 0;
    let userAnswers = [];
    let isRecording = false;
    let recognition = null;

    const quizQuestions = [
      {q: "What is 2+2?", a: "4"},
      {q: "Capital of France?", a: "paris"},
      {q: "Who wrote Romeo and Juliet?", a: "shakespeare"}
    ];

    // Check for saved API key on load
    window.onload = function() {
      const saved = localStorage.getItem('purab_api_key');
      if (saved) {
        apiKey = saved;
        showChat();
        addMessage('bot', "Welcome back! I'm Purab AI, your personal assistant. How can I help you today?");
      }

      // Load conversation history
      const savedHistory = localStorage.getItem('purab_history');
      if (savedHistory) {
        conversationHistory = JSON.parse(savedHistory);
      }

      // Auto-resize textarea
      const input = document.getElementById('message-input');
      input.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
      });

      // Initialize speech recognition
      if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SpeechRecognition();
        recognition.continuous = false;
        recognition.interimResults = false;

        recognition.onresult = function(event) {
          const transcript = event.results[0][0].transcript;
          document.getElementById('message-input').value = transcript;
          isRecording = false;
          document.getElementById('voice-btn').classList.remove('recording');
        };

        recognition.onerror = function() {
          isRecording = false;
          document.getElementById('voice-btn').classList.remove('recording');
        };

        recognition.onend = function() {
          isRecording = false;
          document.getElementById('voice-btn').classList.remove('recording');
        };
      }
    };

    function saveApiKey() {
      const key = document.getElementById('api-key-input').value.trim();
      if (!key || !key.startsWith('sk-ant-')) {
        showError('Please enter a valid Anthropic API key (starts with sk-ant-)');
        return;
      }
      
      apiKey = key;
      localStorage.setItem('purab_api_key', key);
      showChat();
      addMessage('bot', "Hello! I'm Purab AI, always here to help you. Ask me anything!");
    }

    function showError(msg) {
      const errorDiv = document.getElementById('error-msg');
      errorDiv.textContent = msg;
      errorDiv.style.display = 'block';
    }

    function showChat() {
      document.getElementById('setup-screen').style.display = 'none';
      document.getElementById('chat-screen').style.display = 'flex';
    }

    function logout() {
      if (confirm('Are you sure you want to logout? This will clear your API key.')) {
        localStorage.removeItem('purab_api_key');
        apiKey = '';
        document.getElementById('chat-screen').style.display = 'none';
        document.getElementById('setup-screen').style.display = 'flex';
        document.getElementById('api-key-input').value = '';
        document.getElementById('chat-messages').innerHTML = '';
        conversationHistory = [];
      }
    }

    function clearMemory() {
      if (confirm('Clear conversation memory?')) {
        conversationHistory = [];
        localStorage.removeItem('purab_history');
        document.getElementById('chat-messages').innerHTML = '';
        addMessage('bot', "Memory cleared! Starting fresh.");
      }
    }

    function toggleVoice() {
      if (!recognition) {
        alert('Speech recognition is not supported in your browser.');
        return;
      }

      if (isRecording) {
        recognition.stop();
        isRecording = false;
        document.getElementById('voice-btn').classList.remove('recording');
      } else {
        recognition.start();
        isRecording = true;
        document.getElementById('voice-btn').classList.add('recording');
      }
    }

    function handleKeyPress(event) {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        sendMessage();
      }
    }

    function handleImageUpload(event) {
      const file = event.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = function(e) {
        const base64 = e.target.result.split(',')[1];
        sendMessageWithImage(base64);
      };
      reader.readAsDataURL(file);
      event.target.value = '';
    }

    async function sendMessageWithImage(base64Image) {
      const msg = document.getElementById('message-input').value.trim() || "What's in this image?";
      document.getElementById('message-input').value = '';
      
      addMessage('user', msg, base64Image);
      showTyping();

      try {
        const response = await fetch('https://api.anthropic.com/v1/messages', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-api-key': apiKey,
            'anthropic-version': '2023-06-01'
          },
          body: JSON.stringify({
            model: 'claude-sonnet-4-20250514',
            max_tokens: 1024,
            messages: [
              ...conversationHistory,
              {
                role: 'user',
                content: [
                  {
                    type: 'image',
                    source: {
                      type: 'base64',
                      media_type: 'image/jpeg',
                      data: base64Image
                    }
                  },
                  {
                    type: 'text',
                    text: msg
                  }
                ]
              }
            ]
          })
        });

        hideTyping();
        const data = await response.json();
        
        if (data.content && data.content[0]) {
          const reply = data.content[0].text;
          addMessage('bot', reply);
          
          conversationHistory.push({
            role: 'user',
            content: msg + ' [image sent]'
          });
          conversationHistory.push({
            role: 'assistant',
            content: reply
          });
          saveHistory();
        }
      } catch (error) {
        hideTyping();
        addMessage('bot', 'Sorry, there was an error processing your image. Please try again.');
      }
    }

    async function sendMessage() {
      const input = document.getElementById('message-input');
      const msg = input.value.trim();
      if (!msg) return;

      input.value = '';
      input.style.height = 'auto';
      
      addMessage('user', msg);

      // Check for special commands
      if (msg.toLowerCase().includes('generate pdf')) {
        generatePDF();
        return;
      }

      // Check for quiz mode
      if (quizMode) {
        const reply = handleQuiz(msg);
        setTimeout(() => addMessage('bot', reply), 500);
        return;
      }

      // Check personality responses
      const personalityReply = getPersonalityResponse(msg.toLowerCase());
      if (personalityReply) {
        setTimeout(() => addMessage('bot', personalityReply), 500);
        
        conversationHistory.push({role: 'user', content: msg});
        conversationHistory.push({role: 'assistant', content: personalityReply});
        saveHistory();
        return;
      }

      // Call Claude API
      showTyping();
      
      try {
        const response = await fetch('https://api.anthropic.com/v1/messages', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-api-key': apiKey,
            'anthropic-version': '2023-06-01'
          },
          body: JSON.stringify({
            model: 'claude-sonnet-4-20250514',
            max_tokens: 1024,
            messages: [
              ...conversationHistory,
              {role: 'user', content: msg}
            ]
          })
        });

        hideTyping();
        const data = await response.json();
        
        if (data.content && data.content[0]) {
          const reply = data.content[0].text;
          addMessage('bot', reply);
          
          conversationHistory.push({role: 'user', content: msg});
          conversationHistory.push({role: 'assistant', content: reply});
          saveHistory();
        } else if (data.error) {
          addMessage('bot', `Error: ${data.error.message}`);
        }
      } catch (error) {
        hideTyping();
        addMessage('bot', 'Sorry, I encountered an error. Please check your API key and try again.');
      }
    }

    function getPersonalityResponse(msg) {
      if (msg.includes("i am boar") || msg.includes("i'm bored")) {
        quizMode = true;
        quizStep = 0;
        userAnswers = [];
        return "Let's play quiz! " + quizQuestions[quizStep].q;
      }

      if (["hi","hello","hey","what's up","who are you"].some(p => msg.includes(p))) {
        return "I'm Purab AI bot, always here to help you.";
      }
      if (msg.includes("how are you")) return "I'm fine 🙂 You?";
      if (msg.includes("i'm happy") || msg.includes("i am happy")) return "That's great!";
      if (msg.includes("i'm sad") || msg.includes("i am sad") || msg.includes("i'm upset")) return "Krishna is always with you.";
      if (msg.includes("what are you doing")) return "Talking with you 🙂";
      if (msg.includes("newton 3rd law") || msg.includes("newton's 3rd law")) return "I also forget his 3rd law!";
      if (msg.includes("favorite car") || msg.includes("favourite car")) return "Supra!";
      if (msg.includes("favorite president") || msg.includes("favourite president")) return "Xi Jing Ping";

      // Math calculation
      if (/^[0-9+\-*/(). ]+$/.test(msg)) {
        try { 
          return "Answer: " + eval(msg); 
        } catch { 
          return "I couldn't calculate that."; 
        }
      }

      if (msg.includes("bye")) return "Come back fast.";

      return null; // Use Claude API
    }

    function handleQuiz(answer) {
      userAnswers.push(answer.toLowerCase());

      quizStep++;
      if (quizStep < quizQuestions.length) {
        return quizQuestions[quizStep].q;
      } else {
        quizMode = false;
        let correct = true;
        for (let i = 0; i < quizQuestions.length; i++) {
          if (!userAnswers[i].includes(quizQuestions[i].a)) {
            correct = false;
          }
        }
        return correct ? "Good! You got them all right! 🎉" : "Not bad! Try again sometime!";
      }
    }

    function addMessage(sender, text, imageData = null) {
      const messagesDiv = document.getElementById('chat-messages');
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${sender}`;
      
      const avatar = document.createElement('div');
      avatar.className = 'message-avatar';
      avatar.textContent = sender === 'bot' ? 'PA' : 'You';
      
      const content = document.createElement('div');
      content.className = 'message-content';
      content.textContent = text;

      if (imageData) {
        const img = document.createElement('img');
        img.className = 'message-image';
        img.src = 'data:image/jpeg;base64,' + imageData;
        content.appendChild(img);
      }
      
      messageDiv.appendChild(avatar);
      messageDiv.appendChild(content);
      messagesDiv.appendChild(messageDiv);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    function showTyping() {
      const messagesDiv = document.getElementById('chat-messages');
      const typingDiv = document.createElement('div');
      typingDiv.className = 'message bot';
      typingDiv.id = 'typing-indicator';
      
      const avatar = document.createElement('div');
      avatar.className = 'message-avatar';
      avatar.textContent = 'PA';
      
      const content = document.createElement('div');
      content.className = 'message-content typing-indicator';
      content.style.display = 'flex';
      content.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
      
      typingDiv.appendChild(avatar);
      typingDiv.appendChild(content);
      messagesDiv.appendChild(typingDiv);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    function hideTyping() {
      const typing = document.getElementById('typing-indicator');
      if (typing) typing.remove();
    }

    function saveHistory() {
      // Keep last 20 messages to avoid storage limit
      if (conversationHistory.length > 20) {
        conversationHistory = conversationHistory.slice(-20);
      }
      localStorage.setItem('purab_history', JSON.stringify(conversationHistory));
    }

    function generatePDF() {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();
      
      doc.setFontSize(20);
      doc.text('Purab AI - Conversation History', 20, 20);
      
      doc.setFontSize(12);
      let y = 40;
      
      conversationHistory.forEach((msg, i) => {
        if (y > 270) {
          doc.addPage();
          y = 20;
        }
        
        const role = msg.role === 'user' ? 'You' : 'Purab AI';
        const text = `${role}: ${msg.content}`;
        const lines = doc.splitTextToSize(text, 170);
        
        doc.text(lines, 20, y);
        y += lines.length * 7 + 5;
      });
      
      doc.save('purab-ai-conversation.pdf');
      addMessage('bot', 'PDF generated and downloaded! 📄');
    }
  </script>
</body>
</html>
